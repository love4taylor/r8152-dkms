#!/usr/bin/make -f

include /usr/share/dpkg/pkg-info.mk

PACKAGE_ROOT := $(CURDIR)/debian/r8152-dkms
DKMS_SOURCE_DIR := $(PACKAGE_ROOT)/usr/src/r8152-$(DEB_VERSION_UPSTREAM)

%:
	dh $@ --with dkms

override_dh_auto_clean:

override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_install:
	$(MAKE) dkms-source DKMS_SOURCE_DIR=$(DKMS_SOURCE_DIR)

override_dh_dkms:
	dh_dkms -V $(DEB_VERSION_UPSTREAM)
